{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Sync": {
    "Interval": "00:01:00",
    "InvertPowerSign": false,
    "Tolerances": {
      "SocPercent": 0.5,
      "PowerKw": 0.1,
      "SpeedKmh": 0.5,
      "LatLonDegrees": 0.00001
    }
  },
  "Ford": {
    "BaseUrl": "https://api.vehicle.ford.com/fcon-query/",
    "TelemetryPath": "v1/telemetry",
    "AuthorizeUrl": "https://dah2vb2cprod.b2clogin.com/dah2vb2cprod.onmicrosoft.com/B2C_1A_FCON_AUTHORIZE/oauth2/v2.0/authorize",
    "TokenUrl": "https://dah2vb2cprod.b2clogin.com/dah2vb2cprod.onmicrosoft.com/B2C_1A_FCON_AUTHORIZE/oauth2/v2.0/token",
    "Scope": "openid offline_access",
    "TokenFilePath": "./data/ford-token.json",
    "KeysDirectory": "./data/keys"
  },
  "Abrp": {
    "BaseUrl": "https://api.iternio.com/",
    "SendPath": "1/tlm/send"
  },
  "Resilience": {
    "Ford": {
      "Retry": {
        "MaxRetryAttempts": 3
      }
    },
    "Abrp": {
      "Retry": {
        "MaxRetryAttempts": 3
      }
    }
  }
}
